# ── Supabase (optional) ────────────────────────────────────────────────
# The game is fully playable WITHOUT these (it falls back to localStorage).
# Set them to enable cloud saves and the 全国番長ランキング (online ranking).
#
# Get them from: Supabase Dashboard → Project Settings → API
#
# Server-only. The service role key must NEVER be exposed to the browser,
# so it is intentionally NOT prefixed with NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
